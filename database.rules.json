{
  "rules": {
    "rooms": {
      "$roomCode": {
        ".read": true,
        ".write": false,
        "state": {
          ".read": true,
          ".write": false
        },
        "players": {
          "$playerId": {
            ".read": true,
            ".write": false
          }
        },
        "privatePlayerData": {
          "$playerId": {
            ".read": "auth != null && auth.uid == $playerId",
            ".write": false
          }
        }
      }
    }
  }
}
