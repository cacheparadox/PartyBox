rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Rooms — full access for client-direct architecture
    match /rooms/{roomCode} {
      allow read, write: if true;
    }
    
    // Players — full access for client-direct architecture
    match /rooms/{roomCode}/players/{playerId} {
      allow read, write: if true;
    }
    
    // Content packs — publicly readable
    match /contentPacks/{packId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    match /contentPacks/{packId}/entries/{entryId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
