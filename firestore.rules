rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Rooms — any authenticated user can read; only valid host can write
    match /rooms/{roomCode} {
      allow read: if true;
      allow create: if true; // anonymous room creation
      allow update: if true; // room updates handled by Cloud Functions
      allow delete: if false;
    }
    
    // Players — readable by anyone with the room code
    match /rooms/{roomCode}/players/{playerId} {
      allow read: if true;
      allow write: if false; // all writes via Cloud Functions
    }
    
    // Content packs — publicly readable, admin-only write
    match /contentPacks/{packId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    match /contentPacks/{packId}/entries/{entryId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
